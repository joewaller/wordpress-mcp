# WordPress MCP Server — Environment Variables
# Copy to .env and fill in values

# finder.com.au Production
WP_FINDER_COM_AU_PROD_USER=workspace-automation
WP_FINDER_COM_AU_PROD_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Backup database path (defaults to ./data/wp-backups.db)
WP_BACKUP_DB_PATH=
